# Required
JWT_SECRET=your-secret-key-min-32-chars-long

# Required — dev|staging|production
ENVIRONMENT=dev

# Optional — defaults to 8080
PORT=8080

# Required for AI coaching (set in Railway dashboard, not in GitHub Actions)
ANTHROPIC_API_KEY=sk-ant-...

# Future
# OPENAI_API_KEY=sk-...
# SENTRY_DSN=https://...
