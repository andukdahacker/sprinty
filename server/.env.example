# Required
JWT_SECRET=your-secret-key-min-32-chars-long

# Required — dev|staging|production
ENVIRONMENT=dev

# Optional — defaults to 8080
PORT=8080

# Required for AI coaching (set in Railway dashboard, not in GitHub Actions)
ANTHROPIC_API_KEY=sk-ant-...

# Apple App Store Server API (optional in dev, required in staging/production)
# APPLE_KEY_ID=ABC1234567
# APPLE_ISSUER_ID=12345678-1234-1234-1234-123456789012
# APPLE_BUNDLE_ID=com.ducdo.sprinty
# APPLE_PRIVATE_KEY=<base64-encoded PEM private key>

# Future
# OPENAI_API_KEY=sk-...
# SENTRY_DSN=https://...
