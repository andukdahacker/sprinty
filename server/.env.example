# Required
JWT_SECRET=your-secret-key-min-32-chars-long

# Required — dev|staging|production
ENVIRONMENT=dev

# Optional — defaults to 8080
PORT=8080

# Required for AI coaching (set in Railway dashboard, not in GitHub Actions)
ANTHROPIC_API_KEY=sk-ant-...

# Apple App Store Server API (optional in dev, required in staging/production)
# APPLE_KEY_ID=ABC1234567
# APPLE_ISSUER_ID=12345678-1234-1234-1234-123456789012
# APPLE_BUNDLE_ID=com.ducdo.sprinty
# APPLE_PRIVATE_KEY=<base64-encoded PEM private key>

# OpenAI API key (required if any tier uses openai provider)
# OPENAI_API_KEY=sk-...

# Tier-based model routing (defaults shown)
# FREE_TIER_PROVIDER=anthropic
# FREE_TIER_MODEL=claude-haiku-4-5-20251001
# PREMIUM_TIER_PROVIDER=anthropic
# PREMIUM_TIER_MODEL=claude-sonnet-4-6-20250514

# Soft guardrail daily session limits (defaults shown)
# FREE_TIER_DAILY_SESSION_LIMIT=5
# PREMIUM_TIER_DAILY_SESSION_LIMIT=0

# Future
# SENTRY_DSN=https://...
